ENV=development

# Postgres
POSTGRES_USER=avrovo
POSTGRES_PASSWORD=avrovo
POSTGRES_DB=avrovo

# JWT
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379/0

# AI
LLM_PROVIDER=mock        # mock | openai | ollama
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434

# Service URLs (used by api-gateway)
PATIENT_SERVICE_URL=http://patient-service:8001
AI_ENGINE_URL=http://ai-engine:8002
AUTH_SERVICE_URL=http://auth-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
